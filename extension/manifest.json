{
  "name": "Email Reply AI Extension",
  "description": "AI-powered email reply generator that helps you craft responses quickly and efficiently.",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:8080/*", "*://mail.google.com/*"],
  "action": {
    "default_title": "Email Reply AI Extension"
  },
   "content_scripts": [
    {
      "js": ["content.js"],
      "css": ["style.css"],
      "matches": ["*://mail.google.com/*"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["*://mail.google.com/*"]
    }
  ]
}